import sympy as sp

# Initialize symbols
B, X, M_P, xi = sp.symbols('B X M_P xi', real=True, positive=True)
f = M_P**2 / 2

# Define the UBM 4.6 Lagrangian Functions
A1 = 0
A2 = 0
A3 = (xi / M_P) * sp.exp(-B / M_P)
A4 = -A3**2 / (4 * f)
# The A5 closing relation for degeneracy
A5 = (A3 / (2 * (f + X * A3))) * ((3 * X * A3**2) / (4 * f) - A3)

# 1. Verify Degeneracy (Ghost-Free Condition)
# Condition: 4f*A4 + A3^2 must equal 0
degeneracy_check = sp.simplify(4 * f * A4 + A3**2)
print(f"Degeneracy Check (Should be 0): {degeneracy_check}")

# 2. Derive the Stability Parameter Q(X)
# Q = (A3^2 * X)/(4f) + A4 + (3*(A3/2)**2)/(2f + 3X*A3)
Q = (A3**2 * X)/(4*f) + A4 + (3*(A3/2)**2)/(2*f + 3*X*A3)
Q_simplified = sp.simplify(Q)

print("\nSimplified Stability Parameter Q(X):")
sp.pprint(Q_simplified)

# 3. Positivity Test
# Evaluated at xi = 1.21e-12, M_P = 1, X = 0.5
val_Q = Q_simplified.subs({xi: 1.21e-12, M_P: 1, X: 0.5})
print(f"\nNumerical Q at X=0.5: {val_Q}")
print(f"Stable (Q > 0): {val_Q > 0}")
